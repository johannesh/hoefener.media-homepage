---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";
import ServiceList from "@/components/widgets/ServiceList.astro";
import Values from "@/components/widgets/Values.astro";
import Content2 from "@/components/widgets/Content2.astro";
import devImg from "@/assets/images/dev_balanced.png";

const metadata = {
  title: "hoefener.media — Web-Engineering. Sicher. Skalierbar. Schön.",
  description:
    "Webdesign & Web-Engineering aus dem Fichtelgebirge. 10 Jahre Erfahrung, DevOps-Expertise und ein Auge für schönes Design.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <!-- Hero -->
  <Hero
    title={`<span id="typewriter-text" aria-live="polite">Web-Engineering</span><span class="typewriter-cursor" aria-hidden="true">|</span>.<br class="hidden md:block" /><span class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Sicher. Skalierbar. Schön.</span>`}
    tagline="hoefener.media"
    description="Ich verbinde 10 Jahre Webdesign-Erfahrung mit meiner Expertise als Head of DevOps. Das Ergebnis: schnelle Webpräsenzen, die Ihre Kunden begeistern."
    actions={[
      {
        text: "Leistungen entdecken",
        href: "/#leistungen",
        variant: "primary",
        icon: "lucide:arrow-down",
      },
      {
        text: "Kontakt aufnehmen",
        href: "/contact",
        variant: "secondary",
        icon: "lucide:mail",
        ariaLabel: "Jetzt Kontakt aufnehmen",
      },
    ]}
  />

  <!-- Stärken / Features -->
  <Features
    id="staerken"
    tagline="Meine Stärken"
    title="Design trifft Ingenieurskunst"
    subtitle="Als Head of DevOps denke ich Webdesign weiter als andere — von der ersten Skizze bis zum sicheren, wartbaren Betrieb."
    features={[
      {
        title: "Responsives Design",
        description:
          "Perfekte Darstellung auf allen Geräten — von Smartphone bis Widescreen-Monitor. Mobile First ist bei mir kein Buzzword, sondern Standard.",
        icon: "lucide:monitor-smartphone",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Performance & Ladezeit",
        description:
          "Optimierte Assets, schnelle Server-Infrastruktur und moderne Frameworks sorgen für Ladezeiten unter einer Sekunde.",
        icon: "lucide:zap",
        iconClass: "bg-yellow-500/10 text-yellow-400",
      },
      {
        title: "Sicherheit by Design",
        description:
          "DevOps-Expertise bedeutet: SSL/TLS, sichere Deployments, regelmäßige Updates und Schutz gegen die OWASP Top 10 — von Anfang an eingebaut.",
        icon: "lucide:shield-check",
        iconClass: "bg-green-500/10 text-green-400",
      },
      {
        title: "SEO-Optimierung",
        description:
          "Strukturierte Daten, sauberes HTML, schnelle Ladezeiten und sprechende URLs — damit Sie bei Google gefunden werden.",
        icon: "lucide:search",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Skalierbarkeit",
        description:
          "Technologien, die mit Ihrem Unternehmen wachsen. Egal ob kleines Unternehmen heute oder großes Wachstum morgen.",
        icon: "lucide:trending-up",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
      {
        title: "10+ Jahre Erfahrung",
        description:
          "Seit über einem Jahrzehnt baue ich Websites mit WordPress und modernen Web-Technologien — für Kunden aus der Region und darüber hinaus.",
        icon: "lucide:calendar-check",
        iconClass: "bg-orange-500/10 text-orange-400",
      },
    ]}
  />

  <!-- Leistungen -->
  <ServiceList
    id="leistungen"
    tagline="Leistungen"
    title="Was ich für Sie umsetze"
    subtitle="Von der ersten Idee bis zum laufenden Betrieb — alles aus einer Hand."
    services={[
      {
        title: "Webdesign & Entwicklung",
        description:
          "Individuelle Websites, die Ihre Marke widerspiegeln. Ich designe und entwickle moderne, schnelle und barrierefreie Webpräsenzen — maßgeschneidert für Ihr Unternehmen.",
        icon: "lucide:layout-template",
      },
      {
        title: "WordPress & CMS",
        description:
          "Professionelle WordPress-Websites, die Sie selbst verwalten können. Ich richte alles ein, erkläre alles verständlich und bin bei Fragen weiterhin für Sie da.",
        icon: "lucide:pen-tool",
      },
      {
        title: "Hosting & Betrieb",
        description:
          "Sicheres Hosting, automatische Backups, SSL-Zertifikate und regelmäßige Updates. Mit DevOps-Expertise überwache ich den Betrieb Ihrer Website professionell.",
        icon: "lucide:server",
      },
    ]}
  />

  <!-- Über mich / Mein Ansatz -->
  <Content2
    id="ueber-mich"
    items={[
      {
        title: "Beruflich verwurzelt in DevOps",
        description:
          "Als Head of DevOps kenne ich die Strukturen hinter skalierbaren Systemen — dieses Wissen fließt direkt in jede Website ein, die ich entwickle.",
        icon: "lucide:code-2",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Regional verbunden",
        description:
          "Ich bin im Fichtelgebirge/Franken verwurzelt und freue mich besonders auf Projekte aus der Region — persönlicher Kontakt ist mir wichtig.",
        icon: "lucide:map-pin",
        iconClass: "bg-green-500/10 text-green-400",
      },
      {
        title: "Transparent & verlässlich",
        description:
          "Klare Kommunikation, realistische Zeitpläne und Preise ohne versteckte Kosten. Sie wissen immer, woran wir gerade arbeiten.",
        icon: "lucide:handshake",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
    ]}
    image={devImg}
    imageAlt="Web-Entwicklung mit Sorgfalt"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Webdesign mit Tiefe
      </h3>
      Nebenberuflich, aber mit vollem Einsatz: Ich bringe die Qualität und das Denken
      eines erfahrenen Software-Ingenieurs in jedes Webprojekt ein — egal wie groß
      oder klein.
    </Fragment>
  </Content2>

  <!-- Portfolio / Referenzen -->
  <Values
    id="portfolio"
    tagline="Portfolio"
    title="Ausgewählte Referenzen"
    subtitle="Einige Projekte, die ich mit Leidenschaft umgesetzt habe. Weitere Details auf Anfrage."
    columns={3}
    items={[
      {
        title: "Handwerksbetrieb Website",
        description:
          "Moderne WordPress-Website für einen regionalen Handwerksbetrieb — mit Online-Terminbuchung, mobilem Layout und lokalem SEO.",
        icon: "lucide:hammer",
      },
      {
        title: "Dienstleister Landing Page",
        description:
          "Schnelle, conversion-optimierte Landing Page für einen Dienstleister aus Franken. Gebaut mit Astro, gehostet auf Vercel.",
        icon: "lucide:briefcase",
      },
      {
        title: "Vereins-Website",
        description:
          "Pflegeleichte WordPress-Site für einen lokalen Verein — inkl. Veranstaltungskalender, Mitgliederbereich und DSGVO-konformen Formularen.",
        icon: "lucide:users",
      },
    ]}
  />

  <!-- Kontakt CTA -->
  <Features
    id="kontakt"
    isDark={true}
    tagline="Jetzt starten"
    title="Ihr Projekt verdient das Beste"
    subtitle="Sie haben eine Idee oder möchten Ihre bestehende Website verbessern? Ich freue mich auf Ihre Nachricht — unverbindlich und unkompliziert."
    features={[
      {
        title: "Kostenloses Erstgespräch",
        description:
          "In einem kurzen Telefonat oder per Video-Call besprechen wir Ihr Vorhaben und ich gebe Ihnen eine erste Einschätzung.",
        icon: "lucide:phone",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Angebot innerhalb von 48h",
        description:
          "Nach unserem Gespräch erhalten Sie ein detailliertes Angebot mit klarem Leistungsumfang und transparenter Preisgestaltung.",
        icon: "lucide:file-text",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Persönliche Betreuung",
        description:
          "Kein Callcenter, kein Ticketsystem. Sie haben immer einen direkten Ansprechpartner — von Anfang bis Ende.",
        icon: "lucide:user-check",
        iconClass: "bg-green-500/10 text-green-400",
      },
    ]}
  />

  <!-- CTA Button -->
  <div class="dark relative not-prose">
    <div
      class="relative mx-auto max-w-7xl px-4 md:px-6 py-2 md:py-4 text-center pb-16 md:pb-20"
    >
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-primary text-primary-foreground font-semibold text-lg hover:bg-primary/90 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
            d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
        >
        Nachricht schreiben
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  const words = [
    "Web-Design",
    "Web-Engineering",
    "Web-Apps",
    "Web-Development",
  ];
  const TYPING_SPEED = 80;
  const DELETING_SPEED = 50;
  const PAUSE_DURATION = 5000;

  let currentWordIndex = 1; // "Web-Engineering" is shown first
  let isDeleting = false;
  let charIndex = words[1].length;
  let typewriterTimer: number | null = null;

  function type(): void {
    const textEl = document.getElementById("typewriter-text");
    if (!textEl) return;

    const currentWord = words[currentWordIndex];

    if (isDeleting) {
      charIndex--;
      textEl.textContent = currentWord.substring(0, charIndex);

      if (charIndex === 0) {
        isDeleting = false;
        currentWordIndex = (currentWordIndex + 1) % words.length;
        typewriterTimer = window.setTimeout(type, TYPING_SPEED);
      } else {
        typewriterTimer = window.setTimeout(type, DELETING_SPEED);
      }
    } else {
      const word = words[currentWordIndex];
      charIndex++;
      textEl.textContent = word.substring(0, charIndex);

      if (charIndex === word.length) {
        typewriterTimer = window.setTimeout(() => {
          isDeleting = true;
          type();
        }, PAUSE_DURATION);
      } else {
        typewriterTimer = window.setTimeout(type, TYPING_SPEED);
      }
    }
  }

  function initTypewriter(): void {
    if (typewriterTimer !== null) {
      window.clearTimeout(typewriterTimer);
      typewriterTimer = null;
    }

    const textEl = document.getElementById("typewriter-text");
    if (!textEl) return;

    // Respect the user's motion preferences
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    currentWordIndex = 1;
    isDeleting = false;
    charIndex = words[currentWordIndex].length;
    textEl.textContent = words[currentWordIndex];

    typewriterTimer = window.setTimeout(() => {
      isDeleting = true;
      type();
    }, PAUSE_DURATION);
  }

  document.addEventListener("astro:page-load", initTypewriter);
</script>
